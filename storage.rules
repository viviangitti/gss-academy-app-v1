rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // PDFs de condições comerciais
    // - Leitura pública (qualquer um pode abrir o link)
    // - Escrita só para usuários autenticados (admin já é validado no Firestore)
    match /pdfs/conditions/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
      allow delete: if request.auth != null;
    }

    // Prints de comprovação de post (social selling)
    // - Leitura: qualquer usuário autenticado (gestor vê a galeria)
    // - Escrita: só o próprio dono do caminho (uid), imagem até 10 MB
    match /contentProofs/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Bloqueia tudo mais por padrão
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
