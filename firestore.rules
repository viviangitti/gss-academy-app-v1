// Regras de segurança do Firestore — MAESTR.IA em Vendas
// Para aplicar: Console Firebase → Firestore → Rules → cole este conteúdo → Publicar

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar: usuário autenticado?
    function isSignedIn() {
      return request.auth != null;
    }

    // Cérebro coletivo: casos reais anônimos por empresa.
    // Qualquer usuário logado registra/lê (filtro por empresa é feito na query).
    // Sem update/delete — casos são imutáveis (apenas append).
    match /salesCases/{caseId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // Tokens de push (FCM). O id do doc é o próprio token.
    // Cliente registra/atualiza o seu; o envio é feito pelo admin SDK (ignora rules).
    match /pushTokens/{token} {
      allow create, update: if isSignedIn();
      allow read, delete: if false;
    }

    // Função auxiliar: é o dono do documento?
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Função auxiliar: é admin da plataforma? (campo isAdmin no perfil do usuário)
    function isPlatformAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Função auxiliar: pode gerenciar campanhas e condições comerciais?
    // Admin, marketing ou vendas podem criar/editar campanhas, ofertas e condições.
    function isCampaignManager() {
      let profile = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && (
        profile.isAdmin == true ||
        profile.isMarketing == true ||
        profile.userAccessType == 'marketing' ||
        profile.userAccessType == 'vendas' ||
        profile.userAccessType == 'ambos'
      );
    }

    // Função auxiliar: é admin de um time específico?
    function isTeamAdmin(teamId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.adminId == request.auth.uid;
    }

    // Função auxiliar: mesmo time?
    function sameTeam(otherUid) {
      let myProfile = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let otherProfile = get(/databases/$(database)/documents/users/$(otherUid)).data;
      return myProfile.teamId != null && myProfile.teamId == otherProfile.teamId;
    }

    // /users/{uid}
    // - O dono lê/escreve os próprios dados
    // - Admin do time lê os dados dos membros do time
    match /users/{uid} {
      allow read: if isOwner(uid) ||
        (isSignedIn() &&
         resource.data.teamId != null &&
         isTeamAdmin(resource.data.teamId));
      allow write: if isOwner(uid);

      // Subcoleções: vendas, dias, histórico, favoritos
      match /sales/{saleId} {
        allow read: if isOwner(uid) ||
          (isSignedIn() && sameTeam(uid) &&
           get(/databases/$(database)/documents/users/$(uid)).data.teamId != null &&
           isTeamAdmin(get(/databases/$(database)/documents/users/$(uid)).data.teamId));
        allow write: if isOwner(uid);
      }
      match /{subcollection}/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // /teams/{teamId}
    // - Qualquer um autenticado pode ler (pra validar código ao entrar)
    // - Só o admin escreve (exceto memberIds que qualquer membro pode adicionar a si mesmo)
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.adminId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Admin pode tudo
        resource.data.adminId == request.auth.uid ||
        // Qualquer usuário autenticado pode se adicionar à lista de membros
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
         request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
         request.auth.uid in request.resource.data.memberIds)
      );
      allow delete: if isSignedIn() && resource.data.adminId == request.auth.uid;
    }

    // /competitorOffers — inteligência competitiva (dados públicos, escrita mkt ou admin)
    match /competitorOffers/{docId} {
      allow read: if true;
      allow write: if isCampaignManager();
    }

    // /segmentNews — notícias por segmento (dados públicos, escrita só admin)
    match /segmentNews/{docId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // /offers — campanhas e promoções (leitura pública, escrita mkt ou admin)
    match /offers/{docId} {
      allow read: if true;
      allow write: if isCampaignManager();
    }

    // Função auxiliar: a empresa (concessionária) do usuário logado.
    function myCompany() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.company;
    }

    // Função auxiliar: pode VER todas as condições (gestão), independente da loja.
    // Só admin / marketing / gestor — NÃO o vendedor comum.
    function isConditionsManager() {
      let p = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && (
        p.isAdmin == true ||
        p.isMarketing == true ||
        p.userAccessType == 'marketing' ||
        p.isGestor == true
      );
    }

    // /commercialConditions — condições comerciais.
    // ISOLAMENTO POR LOJA NO SERVIDOR: um vendedor só lê as condições GLOBAIS ('')
    // ou as da PRÓPRIA concessionária. Não há como puxar de outra loja, nem pela API.
    // Gestor/marketing/admin podem ler todas (pra gerir). Escrita: marketing/vendas/admin.
    match /commercialConditions/{docId} {
      allow read: if isSignedIn() && (
        isConditionsManager() ||
        resource.data.company == '' ||
        resource.data.company == myCompany()
      );
      allow write: if isCampaignManager();
    }

    // /contentScores — placar de social selling (ranking da equipe)
    // Leitura: qualquer usuário autenticado (pra ver o ranking)
    // Escrita: só o dono do próprio placar (id = {uid}_{mes})
    match /contentScores/{scoreId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    // /liveStatus — status "em atendimento agora" (id = {uid}).
    // Leitura: autenticado (o gestor vê o time). Escrita: só o próprio dono.
    match /liveStatus/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // /feedbacks — feedback geral do app (formulário). Só cria; ninguém lê pelo app.
    match /feedbacks/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // /aiFeedback — 👍/👎 nas respostas da IA (Boost, Coach). Cria e anexa motivo.
    match /aiFeedback/{docId} {
      allow create, update: if isSignedIn();
      allow read, delete: if false;
    }

    // /dealerships — registro de "primeiro acesso da concessionária = gerente".
    // Qualquer logado lê (pra saber se a loja já tem dono). Só cria quem se declara
    // gerente (managerId = próprio uid) E se o doc ainda não existe (create só passa se ausente).
    // Imutável depois: o primeiro fica como gerente.
    match /dealerships/{key} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.managerId == request.auth.uid;
      allow update, delete: if false;
    }

    // /contentProofs — prints de comprovação de post (social selling).
    // Cada vendedor cria as suas (uid == próprio). Qualquer logado lê (gestor vê a galeria).
    // Imutável: sem update/delete.
    match /contentProofs/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
